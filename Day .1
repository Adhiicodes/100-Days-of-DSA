Problem: Write a C program to insert an element x at a given 1-based position pos in an array of n integers. Shift existing elements to the right to make space.

Input:
- First line: integer n
- Second line: n space-separated integers (the array)
- Third line: integer pos (1-based position)
- Fourth line: integer x (element to insert)

Output:
- Print the updated array (n+1 integers) in a single line, space-separated

Example:
Input:
5
1 2 4 5 6
3
3

Output:
1 2 3 4 5 6

Explanation: Insert 3 at position 3, elements [4,5,6] shift right

#include <stdio.h>

int main() {
    int n, pos, x;   // n = size of array, pos = position to insert (1-based), x = element to insert
    
    scanf("%d", &n);   // Take number of elements
    
    int arr[1000];     // Declare array with enough size
    
    // Input array elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);   // Store elements from index 0 to n-1
    }
    
    scanf("%d", &pos);   // Take position (1-based indexing)
    scanf("%d", &x);     // Take element to insert
    
    // Shift elements to the right to make space
    // Start from the end (index n) and go till position 'pos'
    for (int i = n; i >= pos; i--) {
        arr[i] = arr[i - 1];   // Move each element one step to the right
    }
    
    // Insert element at correct position
    // Convert 1-based position to 0-based index → pos - 1
    arr[pos - 1] = x;
    
    // Print updated array (size becomes n+1)
    for (int i = 0; i <= n; i++) {
        printf("%d ", arr[i]);   // Print all elements including new one
    }
    
    return 0;   // End of program
}
